function fmtHora(n) {
  const h = Number(n);
  if (h === 0)  return '12:00 AM';
  if (h < 12)  return `${String(h).padStart(2,'0')}:00 AM`;
  if (h === 12) return '12:00 PM';
  return `${String(h-12).padStart(2,'0')}:00 PM`;
}
async function saveHorario() {
  const apertura = parseInt(document.getElementById('configApertura').value);
  const cierre   = parseInt(document.getElementById('configCierre').value);
  if (isNaN(apertura)||isNaN(cierre)) { showToast('⚠️ Ingresa apertura y cierre'); return; }
  if (apertura<0||apertura>23||cierre<0||cierre>23) { showToast('⚠️ Valores entre 0 y 23'); return; }
  await db.collection('config').doc('tienda').set({ horario: { apertura, cierre } }, { merge: true });
  const el = document.getElementById('horarioStatus');
  el.textContent = `✅ Horario: ${fmtHora(apertura)} – ${fmtHora(cierre)}${apertura>=cierre?' (nocturno)':''}`;
  showToast('✅ Horario actualizado');
}

