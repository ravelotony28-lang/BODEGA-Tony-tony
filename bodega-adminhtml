async function addProduct() {
  const emoji    = document.getElementById('newEmoji').value.trim() || '📦';
  const name     = document.getElementById('newName').value.trim();
  const price    = parseFloat(document.getElementById('newPrice').value);
  const category = document.getElementById('newCategory').value.trim() || 'General';
  const etiqueta = document.getElementById('newEtiqueta').value || '';
  const tipo     = document.getElementById('newTipo').value || 'normal';
  const oferta   = document.getElementById('newOferta').checked || false;
  const precioAnterior = parseFloat(document.getElementById('newPrecioAnterior').value) || 0;
  const visible  = document.getElementById('newVisible').checked !== false;
  const agotado  = document.getElementById('newAgotado').checked || false;
  const stockVal = document.getElementById('newStock').value;
  const stock    = stockVal !== '' ? parseInt(stockVal) : null;
  if (!name)               { showToast('⚠️ Escribe el nombre'); return; }
  if (isNaN(price)||price<=0) { showToast('⚠️ Precio inválido'); return; }
  showToast('⏳ Guardando...');
  await db.collection('productos').add({ emoji, name, price, category, photo: pendingPhotoBase64, variants: currentVariants, etiqueta, tipo, oferta, precioAnterior: oferta&&precioAnterior?precioAnterior:0, visible, agotado, stock });
  ['newEmoji','newName','newPrice','newCategory','newPrecioAnterior','newStock'].forEach(id => { document.getElementById(id).value = ''; });
  document.getElementById('newEtiqueta').value = '';
  document.getElementById('newOferta').checked = false;
  document.getElementById('newVisible').checked = true;
  document.getElementById('newAgotado').checked = false;
  document.getElementById('newPhoto').value = '';
  document.getElementById('photoPreview').innerHTML = '<span style="font-size:30px">📸</span><span>Toca para agregar foto</span>';
  document.getElementById('photoPreview').style.border = '2px dashed #ddd';
  pendingPhotoBase64 = ''; currentVariants = []; renderVariantTags();
  showToast('✅ Producto agregado');
}

