// ── ACTUALIZAR ESTADO ──
async function updateEstado(id, estado) {
  const updates = { estado };
  if (estado === 'confirmado') {
    updates.fechaConfirmacion = new Date().toISOString();
    const repAsignado = await asignarRepartidorAuto(id);
    if (repAsignado) {
      updates.nombreRepartidor   = repAsignado.nombre;
      updates.telefonoRepartidor = repAsignado.telefono;
      updates.repartidor = { nombre: repAsignado.nombre, telefono: repAsignado.telefono, estado: 'asignado' };
    }
  }
  if (estado === 'preparacion' || estado === 'preparando') updates.fechaPreparacion = new Date().toISOString();
  if (estado === 'camino' || estado === 'en_camino') updates.fechaSalida = new Date().toISOString();
  if (estado === 'entregado') updates.fechaEntrega = new Date().toISOString();
  if (estado === 'cancelado') updates.fechaCancelacion = new Date().toISOString();
  await db.collection('pedidos').doc(id).update(updates);
  const msgs = { pendiente:'⏳ Marcado pendiente', confirmado:'✅ Confirmado', camino:'🛵 En camino', entregado:'📦 Entregado', preparacion:'🍳 En preparación', preparando:'🍳 En preparación', cancelado:'❌ Cancelado' };
  showToast(msgs[estado] || '✅ Estado actualizado');
  // Notificación automática al cliente por WhatsApp
  notificarClienteAuto(id, estado);
}

async function asignarRepartidorAuto(pedidoId) {
  if (!repartidores || repartidores.length === 0) return null;
  const ocupados = new Set(allPedidos.filter(p => p.id !== pedidoId && ['confirmado','preparacion','preparando','camino','en_camino'].includes(p.estado) && p.nombreRepartidor).map(p => p.nombreRepartidor));
  return repartidores.find(r => !ocupados.has(r.nombre)) || null;
}

async function asignarRepartidor(pedidoId, repartidorId) {
  if (!repartidorId) {
    await db.collection('pedidos').doc(pedidoId).update({ repartidor: null, nombreRepartidor: '', telefonoRepartidor: '' });
    showToast('❌ Repartidor removido'); return;
  }
  const rep = repartidores.find(r => r.id === repartidorId);
  if (!rep) return;
  await db.collection('pedidos').doc(pedidoId).update({
    repartidor: { nombre: rep.nombre, telefono: rep.telefono, estado: 'asignado' },
    nombreRepartidor: rep.nombre, telefonoRepartidor: rep.telefono,
  });
  showToast(`🛵 ${rep.nombre} asignado`);
}

// 10. ENVIAR PEDIDO AL REPARTIDOR POR WHATSAPP
function notifRepartidorWA(pedidoId) {
  const pedido  = allPedidos.find(p => p.id === pedidoId);
  if (!pedido) return;
  const repNombre   = pedido.nombreRepartidor || '';
  const repTelefono = pedido.telefonoRepartidor || '';
  if (!repTelefono) { showToast('⚠️ No hay repartidor asignado'); return; }
  const geoLink = pedido.geo ? `https://maps.google.com/?q=${pedido.geo.lat},${pedido.geo.lng}` : 'No disponible';
  let msg = `🛵 *NUEVO PEDIDO*\n\n`;
  msg += `Cliente: ${pedido.nombre}\n`;
  msg += `Tel: ${pedido.telefono}\n`;
  msg += `Ubicación: ${geoLink}\n\n`;
  msg += `*Pedido:*\n${pedido.productos}\n`;
  msg += `Pago: ${pedido.metodoPago||'—'}\n`;
  msg += `Zona: ${pedido.zona||'—'}\n`;
  msg += `Total: $${pedido.total?.toFixed(2)||'0.00'}\n\n`;
  msg += `👉 Confirma cuando lo recibas`;
  const tel = repTelefono.replace(/\D/g,'');
  window.open(`https://wa.me/${tel}?text=${encodeURIComponent(msg)}`, '_blank');
}

function enviarNotifWA(pedidoId) {
  const pedido = allPedidos.find(p => p.id === pedidoId);
  if (!pedido) return;
  const estadoMsgs = {
    pendiente: '⏳ Tu pedido fue recibido y está pendiente.',
    confirmado: '✅ ¡Tu pedido fue confirmado! Lo estamos procesando.',
    preparacion: '🍳 ¡Tu pedido está en preparación! Pronto estará listo.',
    preparando: '🍳 ¡Tu pedido está en preparación! Pronto estará listo.',
    camino: '🛵 ¡Tu pedido está en camino! Prepárate para recibirlo.',
    en_camino: '🛵 ¡Tu pedido está en camino! Prepárate para recibirlo.',
    entregado: '📦 ¡Tu pedido fue entregado! Gracias por comprar en Bodega Tony Tony. 🙏'
  };
  const repNombre   = pedido.nombreRepartidor || '';
  const repTelefono = pedido.telefonoRepartidor || '';
  let msg = `🛒 *Bodega Tony Tony*\n\nHola ${pedido.nombre}! ${estadoMsgs[pedido.estado] || ''}`;
  if ((pedido.estado === 'camino' || pedido.estado === 'en_camino') && repNombre) {
    msg += `\n\n🛵 *Tu repartidor:*\n👤 ${repNombre}\n📞 ${repTelefono}`;
  }
  // Normalizar número: solo dígitos, agregar código Venezuela si no tiene
  let tel = (pedido.telefono || '').replace(/\s+/g,'');
  if (!tel.startsWith('+')) {
    tel = tel.replace(/^0+/, '');
    if (!tel.startsWith('57') && !tel.startsWith('58')) tel = '58' + tel;
    tel = '+' + tel;
  }
  tel = tel.replace(/[^0-9+]/g, '');
  window.open(`https://wa.me/${tel}?text=${encodeURIComponent(msg)}`, '_blank');
}

