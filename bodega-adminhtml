async function updateSoporte(id, estado) {
  await db.collection('soporte').doc(id).update({ estado, fechaActualizacion: new Date().toISOString() });
  if (estado === 'en_revision') {
    showToast('🔍 Marcado en revisión');
    // Confirmación automática al cliente
    const s = allSoporte.find(x => x.id === id);
    if (s && s.telefono) {
      const tel = s.telefono.replace(/\D/g,'');
      const msg = `🛒 *Bodega Tony Tony*\n\nHola ${s.clienteNombre}, tu reporte fue recibido ✅\nEstamos revisando: *${s.tipoProblema}*\nTe contactaremos pronto. ¡Gracias!`;
      setTimeout(() => {
        if (confirm('¿Enviar confirmación automática al cliente por WhatsApp?')) {
          window.open(`https://wa.me/${tel}?text=${encodeURIComponent(msg)}`, '_blank');
        }
      }, 300);
    }
  } else {
    showToast('✅ Reporte resuelto');
  }
}

function responderSoporteWA(id) {
  const s = allSoporte.find(x => x.id === id);
  if (!s) return;
  const tel = s.telefono.replace(/\D/g,'');
  const msg = `🛒 *Bodega Tony Tony*\n\nHola ${s.clienteNombre}, hemos recibido tu reporte sobre: *${s.tipoProblema}*.\nEstamos revisando tu caso y te contactaremos pronto. ¡Gracias por avisarnos!`;
  window.open(`https://wa.me/${tel}?text=${encodeURIComponent(msg)}`, '_blank');
}

