// 1. ESTADÍSTICAS MEJORADAS
function loadStats() {
  const hoy = new Date().toDateString();
  const pedidosHoy   = allPedidos.filter(p => new Date(p.fecha).toDateString() === hoy);
  const entregadosHoy = pedidosHoy.filter(p => p.estado === 'entregado');
  const ventasHoy    = entregadosHoy.reduce((s, p) => s + (p.total||0), 0);
  const enProceso    = allPedidos.filter(p => ['pendiente','confirmado','preparacion','preparando','camino','en_camino'].includes(p.estado)).length;
  const cancelados   = allPedidos.filter(p => p.estado === 'cancelado').length;
  const enCamino     = allPedidos.filter(p => ['camino','en_camino'].includes(p.estado)).length;
  const ingresoTotal = allPedidos.filter(p => p.estado === 'entregado').reduce((s, p) => s + (p.total||0), 0);
  const totalEntregados = allPedidos.filter(p => p.estado === 'entregado').length;
  const ticketPromedio  = totalEntregados > 0 ? ingresoTotal / totalEntregados : 0;

  // Producto más vendido
  const conteo = {};
  allPedidos.forEach(p => {
    if (p.productos) {
      p.productos.split('\n').forEach(linea => {
        const match = linea.match(/^\s*\S+\s+(.+?)\s+×\s+(\d+)/);
        if (match) {
          const nombre = match[1].replace(/\(.*\)/, '').trim();
          const qty    = parseInt(match[2]) || 1;
          conteo[nombre] = (conteo[nombre] || 0) + qty;
        }
      });
    }
  });
  const masVendido = Object.entries(conteo).sort((a,b) => b[1]-a[1])[0];

  // Panel principal
  const el = document.getElementById('statsPanel');
  if (el) {
    el.innerHTML = [
      ['📅', 'Pedidos hoy', pedidosHoy.length, '#ff6b2b'],
      ['💵', 'Ventas hoy', '$'+ventasHoy.toFixed(2), '#2dc653'],
      ['⏳', 'En proceso', enProceso, '#f4d35e'],
      ['❌', 'Cancelados', cancelados, '#e63946'],
      ['💰', 'Total ingresado', '$'+ingresoTotal.toFixed(2), '#e63946'],
      ['🧾', 'Ticket promedio', '$'+ticketPromedio.toFixed(2), '#7b2ff7'],
      ['🏆', 'Más vendido', masVendido ? masVendido[0].slice(0,14) : '—', '#1565c0'],
    ].map(([emoji, label, val, color]) => `
      <div class="stat-card" style="--stat-color:${color};">
        <div style="font-size:22px;">${emoji}</div>
        <div class="stat-val" style="color:${color};">${val}</div>
        <div class="stat-lbl">${label}</div>
      </div>`).join('');
  }

  // Mini-stats en tab pedidos
  const pBar = document.getElementById('pedidosStatsBar');
  if (pBar) {
    pBar.innerHTML = [
      ['⏳', allPedidos.filter(p=>p.estado==='pendiente').length, '#856404','#fff3cd', 'Pendientes'],
      ['🍳', allPedidos.filter(p=>['preparacion','preparando'].includes(p.estado)).length, '#004085','#cce5ff', 'Preparando'],
      ['🛵', enCamino, '#c05621','#ffe5d0', 'En camino'],
      ['📦', entregadosHoy.length, '#155724','#d4edda', 'Entregados hoy'],
      ['❌', cancelados, '#e63946','#ffd6d6', 'Cancelados'],
    ].map(([e, n, color, bg, lbl]) => `
      <div style="background:${bg};border-radius:12px;padding:10px 8px;text-align:center;">
        <div style="font-size:18px;">${e}</div>
        <div style="font-family:'Bebas Neue',sans-serif;font-size:20px;color:${color};">${n}</div>
        <div style="font-size:10px;color:${color};font-weight:700;">${lbl}</div>
      </div>`).join('');
  }
}

