function previewEditPhoto(input) {
  const file = input.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    const img = new Image();
    img.onload = () => {
      const canvas = document.createElement('canvas');
      const MAX = 400; let w = img.width, h = img.height;
      if (w > h) { if (w > MAX) { h = h*MAX/w; w = MAX; } } else { if (h > MAX) { w = w*MAX/h; h = MAX; } }
      canvas.width = w; canvas.height = h;
      canvas.getContext('2d').drawImage(img, 0, 0, w, h);
      editingPhotoBase64 = canvas.toDataURL('image/jpeg', 0.7);
      const prev = document.getElementById('editPhotoPreview');
      prev.innerHTML = `<img src="${editingPhotoBase64}" style="width:100%;height:100%;object-fit:cover;">`;
      prev.style.border = 'none';
    };
    img.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function addEditVariant() {
  const input = document.getElementById('editVariantInput');
  const val = input.value.trim();
  if (!val || editingVariants.includes(val)) return;
  editingVariants.push(val); renderEditVariantTags(); input.value = '';
}
function removeEditVariant(v) { editingVariants = editingVariants.filter(x => x !== v); renderEditVariantTags(); }
function renderEditVariantTags() {
  const el = document.getElementById('editVariantTags');
  if (!el) return;
  el.innerHTML = editingVariants.map(v => `<div class="variant-tag">${v} <button onclick="removeEditVariant('${v}')">×</button></div>`).join('');
}

async function saveEdit(id) {
