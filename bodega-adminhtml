}

async function crearCupon() {
  const codigo    = document.getElementById('cuponCodigo').value.trim().toUpperCase();
  const tipo      = document.getElementById('cuponTipo').value;
  const descuento = parseFloat(document.getElementById('cuponDescuento').value);
  const expira    = document.getElementById('cuponExpira').value;
  if (!codigo)             { showToast('⚠️ Escribe un código'); return; }
  if (isNaN(descuento)||descuento<=0) { showToast('⚠️ Ingresa el valor del descuento'); return; }
  showToast('⏳ Creando cupón...');
  await db.collection('cupones').add({ codigo, tipo, descuento, expira: expira || null, activo: true, fecha: new Date().toISOString(), usos: 0 });
  ['cuponCodigo','cuponDescuento','cuponExpira'].forEach(id => { document.getElementById(id).value = ''; });
  showToast(`✅ Cupón ${codigo} creado`);
}

async function toggleCupon(id, activo) {
  await db.collection('cupones').doc(id).update({ activo: !activo });
  showToast(!activo ? '✅ Cupón activado' : '❌ Cupón desactivado');
}

async function deleteCupon(id) {
  if (!confirm('¿Eliminar este cupón?')) return;
  await db.collection('cupones').doc(id).delete();
  showToast('🗑️ Cupón eliminado');
}

