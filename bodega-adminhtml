  const oferta   = document.getElementById('editOferta').checked;
  const precioAnterior = parseFloat(document.getElementById('editPrecioAnterior').value) || 0;
  const visible  = document.getElementById('editVisible').checked;
  const agotado  = document.getElementById('editAgotado').checked;
  const p = products.find(x => x.id === id);
  if (!name)               { showToast('⚠️ Escribe el nombre'); return; }
