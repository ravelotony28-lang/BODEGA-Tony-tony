async function saveMontoEnvio() {
  const val = parseFloat(document.getElementById('configMontoEnvio').value) || 0;
  await db.collection('config').doc('tienda').set({ montoEnvioGratis: val }, { merge: true });
  showToast(val > 0 ? `✅ Envío gratis desde $${val.toFixed(2)}` : '✅ Monto envío gratis desactivado');
}

// ── EXPORTAR PDF (1 vez al mes con PIN) ──
const PDF_PIN = ADMIN_PIN; // usa el mismo PIN del admin
function exportarPDF() {
  const pin = document.getElementById('pdfPin').value.trim();
  if (pin !== PDF_PIN) { showToast('❌ PIN incorrecto'); return; }

  // Verificar si ya exportó este mes
  const ultimaExport = localStorage.getItem('ultimaExportPDF');
  const ahora = new Date();
  if (ultimaExport) {
    const ultima = new Date(ultimaExport);
    if (ultima.getMonth() === ahora.getMonth() && ultima.getFullYear() === ahora.getFullYear()) {
      const pdfEl = document.getElementById('pdfAuthStatus');
      if (pdfEl) pdfEl.textContent = `⚠️ Ya exportaste este mes (${ultima.toLocaleDateString()})`;
      if (!confirm('Ya exportaste este mes. ¿Deseas exportar de nuevo?')) return;
    }
  }

  // Generar reporte en texto plano (abre ventana imprimible)
  const mes = ahora.toLocaleDateString('es-VE', { month: 'long', year: 'numeric' });
  const pedidosMes = allPedidos.filter(p => {
    const fp = new Date(p.fecha);
    return fp.getMonth() === ahora.getMonth() && fp.getFullYear() === ahora.getFullYear();
  });
  const totalMes = pedidosMes.reduce((s, p) => s + (p.total||0), 0);
  const entregados = pedidosMes.filter(p => p.estado === 'entregado');
  const ingresoReal = entregados.reduce((s, p) => s + (p.total||0), 0);

  let html = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Reporte ${mes}</title>
    <style>body{font-family:Arial,sans-serif;padding:20px;font-size:13px;}h1{font-size:20px;margin-bottom:4px;}h2{font-size:15px;margin:16px 0 8px;border-bottom:1px solid #ddd;padding-bottom:4px;}table{width:100%;border-collapse:collapse;}th,td{padding:6px 8px;border:1px solid #ddd;text-align:left;}th{background:#f0f0f0;font-weight:700;}.total{font-size:15px;font-weight:700;margin-top:12px;}
/* Toast */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--oscuro);color:white;padding:12px 24px;border-radius:50px;font-weight:700;font-size:14px;z-index:999;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);white-space:nowrap;pointer-events:none;box-shadow:0 8px 24px rgba(0,0,0,0.3);}
.toast.show{transform:translateX(-50%) translateY(0);}


.estado-cancelado   { background:#ffd6d6; color:#e63946; }
.pedido-id-badge     { font-family:'Bebas Neue',sans-serif; font-size:18px; color:var(--rojo); letter-spacing:1px; }

</style>
    </head><body>
    <h1>🛒 Bodega Tony Tony</h1>
    <p>Reporte de pedidos — ${mes}</p>
    <p>Generado: ${ahora.toLocaleString('es-VE')}</p>
    <h2>📊 Resumen</h2>
    <table><tr><th>Concepto</th><th>Valor</th></tr>
    <tr><td>Total pedidos</td><td>${pedidosMes.length}</td></tr>
    <tr><td>Pedidos entregados</td><td>${entregados.length}</td></tr>
    <tr><td>Monto total facturado</td><td>$${totalMes.toFixed(2)}</td></tr>
    <tr><td>Ingresos reales (entregados)</td><td>$${ingresoReal.toFixed(2)}</td></tr>
    </table>
    <h2>📋 Detalle de Pedidos</h2>
    <table><tr><th>Fecha</th><th>Cliente</th><th>Teléfono</th><th>Estado</th><th>Total</th></tr>
    ${pedidosMes.map(p => `<tr><td>${new Date(p.fecha).toLocaleDateString('es-VE')}</td><td>${p.nombre}</td><td>${p.telefono}</td><td>${p.estado}</td><td>$${p.total?.toFixed(2)||'0.00'}</td></tr>`).join('')}
    </table>
    <div class="total">Total ingresado: $${ingresoReal.toFixed(2)}</div>
    </body></html>`;

  const win = window.open('', '_blank');
  win.document.write(html);
  win.document.close();
  win.print();

  localStorage.setItem('ultimaExportPDF', ahora.toISOString());
  document.getElementById('pdfPin').value = '';
  const pdfEl = document.getElementById('pdfAuthStatus');
  if (pdfEl) pdfEl.textContent = `✅ Exportado el ${ahora.toLocaleDateString()}`;
  showToast('✅ PDF generado');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}
</script>
