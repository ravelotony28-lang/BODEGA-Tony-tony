<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="#1a1a2e">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-title" content="Admin Tony Tony">
<title>⚙️ Admin - Bodega Tony Tony</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
<style>
:root{--rojo:#e63946;--amarillo:#f4d35e;--verde:#2dc653;--oscuro:#1a1a2e;--sombra:0 4px 20px rgba(0,0,0,0.12);--bg:#f5f5f5;--card:#fff;--text:#1a1a2e;--subtext:#888;--border:#eee;--gris:#f1f1f1;}
.dark-mode{--bg:#0f0f1a;--card:#1a1a2e;--text:#f0f0f0;--subtext:#aaa;--border:#2a2a3e;--gris:#2a2a3e;}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}
header{background:var(--oscuro);color:white;padding:16px 20px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:0 2px 12px rgba(0,0,0,0.3);}
.logo{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--amarillo);}
.logo span{color:var(--rojo);}
.tabs{display:flex;background:var(--card);border-bottom:3px solid var(--amarillo);overflow-x:auto;scrollbar-width:none;}
.tabs::-webkit-scrollbar{display:none;}
.tab-btn{padding:11px 14px;border:none;background:transparent;font-family:'Nunito',sans-serif;font-weight:700;font-size:13px;color:var(--subtext);cursor:pointer;white-space:nowrap;border-bottom:3px solid transparent;margin-bottom:-3px;transition:all 0.2s;}
.tab-btn.active{color:var(--rojo);border-bottom-color:var(--rojo);}
.view{display:none;padding:16px;}
.view.active{display:block;}
.admin-section{background:var(--card);border-radius:16px;padding:18px;box-shadow:var(--sombra);margin-bottom:16px;}
.admin-section h3{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:1px;margin-bottom:14px;color:var(--text);border-left:4px solid var(--rojo);padding-left:10px;}
.form-row{display:flex;gap:10px;margin-bottom:10px;flex-wrap:wrap;}
.form-row input,.form-row select{flex:1;min-width:120px;padding:10px 14px;border:2px solid var(--border);border-radius:10px;font-family:'Nunito',sans-serif;font-size:14px;outline:none;transition:border 0.2s;background:var(--bg);color:var(--text);}
.form-row input:focus,.form-row select:focus{border-color:var(--rojo);}
.btn-primary{background:var(--rojo);color:white;border:none;border-radius:10px;padding:10px 20px;font-family:'Nunito',sans-serif;font-weight:800;font-size:14px;cursor:pointer;}
.btn-secondary{background:var(--oscuro);color:white;border:none;border-radius:10px;padding:10px 20px;font-family:'Nunito',sans-serif;font-weight:800;font-size:14px;cursor:pointer;}
.btn-verde{background:var(--verde);color:white;border:none;border-radius:10px;padding:8px 16px;font-family:'Nunito',sans-serif;font-weight:800;font-size:13px;cursor:pointer;}
.photo-upload-area{width:100%;height:100px;border:2px dashed #ddd;border-radius:12px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;font-size:13px;font-weight:700;color:#999;gap:6px;overflow:hidden;margin-bottom:10px;}
.photo-upload-area img{width:100%;height:100%;object-fit:cover;}
.variants-input-area{margin-bottom:12px;}
.variants-input-area>label{font-size:13px;font-weight:700;display:block;margin-bottom:6px;color:var(--subtext);}
.variant-tags{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:8px;}
.variant-tag{background:var(--oscuro);color:white;border-radius:50px;padding:4px 10px;font-size:12px;font-weight:700;display:flex;align-items:center;gap:5px;}
.variant-tag button{background:none;border:none;color:white;cursor:pointer;font-size:16px;padding:0;line-height:1;}
.variant-add-row{display:flex;gap:8px;}
.variant-add-row input{flex:1;padding:8px 12px;border:2px solid var(--border);border-radius:10px;font-family:'Nunito',sans-serif;font-size:13px;outline:none;background:var(--bg);color:var(--text);}
.variant-add-row button{background:var(--oscuro);color:white;border:none;border-radius:10px;padding:8px 14px;font-weight:800;cursor:pointer;font-size:13px;white-space:nowrap;}
.product-list-admin{display:flex;flex-direction:column;gap:10px;}
.product-item-admin{display:flex;align-items:center;gap:10px;background:var(--gris);border-radius:12px;padding:10px 14px;}
.product-item-admin .thumb{width:44px;height:44px;border-radius:8px;object-fit:cover;flex-shrink:0;}
.product-item-admin .pemoji{font-size:28px;flex-shrink:0;}
.product-item-admin .info{flex:1;min-width:0;}
.product-item-admin .info .name{font-weight:700;font-size:14px;}
.product-item-admin .info .cat{font-size:12px;color:var(--subtext);}
.del-btn{background:none;border:none;font-size:20px;cursor:pointer;padding:4px;border-radius:8px;}
.del-btn:hover{background:#ffd6d6;}
.edit-btn{background:none;border:none;font-size:20px;cursor:pointer;padding:4px;border-radius:8px;}
.edit-btn:hover{background:#fff3cd;}
.pedido-card{background:var(--gris);border-radius:14px;padding:14px;margin-bottom:12px;}
.estado-badge{font-size:11px;font-weight:800;padding:4px 10px;border-radius:50px;white-space:nowrap;}
.estado-pendiente{background:#fff3cd;color:#856404;}
.estado-confirmado{background:#d4edda;color:#155724;}
.estado-preparacion{background:#cce5ff;color:#004085;}
.estado-camino{background:#ffe5d0;color:#c05621;}
.estado-entregado{background:#d4edda;color:#155724;}
/* 14. SOPORTE */
.soporte-card{background:var(--gris);border-radius:14px;padding:14px;margin-bottom:10px;}
.soporte-estado{font-size:11px;font-weight:800;padding:3px 9px;border-radius:50px;}
.s-nuevo{background:#fff3cd;color:#856404;}
.s-revision{background:#cce5ff;color:#004085;}
.s-resuelto{background:#d4edda;color:#155724;}
/* LOCK */
.lock-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;background:var(--oscuro);}
.lock-card{background:#1e1e2e;border-radius:24px;padding:30px 24px;text-align:center;max-width:300px;width:100%;}
.pin-dot{width:16px;height:16px;border-radius:50%;border:2px solid #555;background:transparent;transition:background 0.15s;}
.pin-dot.filled{background:var(--rojo);border-color:var(--rojo);}
.pin-key{background:#2a2a3e;color:white;border:none;border-radius:14px;padding:18px;font-family:'Nunito',sans-serif;font-weight:800;font-size:20px;cursor:pointer;transition:background 0.15s,transform 0.1s;}
.pin-key:active{background:var(--rojo);transform:scale(0.92);}
.repartidor-item{display:flex;align-items:center;gap:10px;background:var(--gris);border-radius:12px;padding:10px 14px;margin-bottom:8px;}
.toggle-switch{position:relative;width:44px;height:24px;flex-shrink:0;}
.toggle-switch input{opacity:0;width:0;height:0;}
.toggle-slider{position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:#ccc;border-radius:24px;transition:0.3s;}
.toggle-slider:before{position:absolute;content:"";height:18px;width:18px;left:3px;bottom:3px;background:white;border-radius:50%;transition:0.3s;}
input:checked+.toggle-slider{background:var(--verde);}
input:checked+.toggle-slider:before{transform:translateX(20px);}
/* stats mejoradas */
.stat-card{background:var(--gris);border-radius:14px;padding:14px;text-align:center;position:relative;overflow:hidden;}
.stat-card::before{content:'';position:absolute;top:0;left:0;width:4px;height:100%;background:var(--stat-color,var(--rojo));}
.stat-val{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:1px;}
.stat-lbl{font-size:11px;color:var(--subtext);font-weight:700;margin-top:2px;}
/* pedido card mejorado */
.pedido-meta{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:6px;}
.pedido-meta-chip{background:var(--card);border:1px solid var(--border);border-radius:50px;padding:2px 8px;font-size:11px;font-weight:700;color:var(--subtext);}
/* config status chip */
.config-ok{color:var(--verde);font-weight:700;font-size:12px;margin-top:6px;}
.config-warn{color:var(--naranja);font-weight:700;font-size:12px;margin-top:6px;}

/* Toast */
.toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(80px);background:var(--oscuro);color:white;padding:12px 24px;border-radius:50px;font-weight:700;font-size:14px;z-index:999;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1);white-space:nowrap;pointer-events:none;box-shadow:0 8px 24px rgba(0,0,0,0.3);}
.toast.show{transform:translateX(-50%) translateY(0);}


.estado-cancelado   { background:#ffd6d6; color:#e63946; }
.pedido-id-badge     { font-family:'Bebas Neue',sans-serif; font-size:18px; color:var(--rojo); letter-spacing:1px; }

</style>
</head>
<body>

<!-- LOCK SCREEN -->
<div class="lock-screen" id="lockScreen">
  <div class="lock-card">
    <div style="font-size:50px;margin-bottom:12px;">🔐</div>
    <div style="font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:2px;margin-bottom:4px;color:white;">ADMIN</div>
    <div style="font-family:'Bebas Neue',sans-serif;font-size:16px;color:var(--rojo);letter-spacing:1px;margin-bottom:20px;">BODEGA TONY TONY</div>
    <div id="pinDisplay" style="display:flex;justify-content:center;gap:12px;margin-bottom:24px;">
      <div class="pin-dot" id="dot0"></div><div class="pin-dot" id="dot1"></div>
      <div class="pin-dot" id="dot2"></div><div class="pin-dot" id="dot3"></div>
      <div class="pin-dot" id="dot4"></div><div class="pin-dot" id="dot5"></div>
    </div>
    <p id="pinError" style="color:var(--rojo);font-size:13px;font-weight:700;margin-bottom:12px;min-height:20px;text-align:center;"></p>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px;max-width:240px;margin:0 auto;">
      <button class="pin-key" onclick="pinPress('1')">1</button>
      <button class="pin-key" onclick="pinPress('2')">2</button>
      <button class="pin-key" onclick="pinPress('3')">3</button>
      <button class="pin-key" onclick="pinPress('4')">4</button>
      <button class="pin-key" onclick="pinPress('5')">5</button>
      <button class="pin-key" onclick="pinPress('6')">6</button>
      <button class="pin-key" onclick="pinPress('7')">7</button>
      <button class="pin-key" onclick="pinPress('8')">8</button>
      <button class="pin-key" onclick="pinPress('9')">9</button>
      <button class="pin-key" onclick="pinClear()" style="background:#555;font-size:14px;">⌫</button>
      <button class="pin-key" onclick="pinPress('0')">0</button>
      <button class="pin-key" onclick="checkPin()" style="background:var(--rojo);">✓</button>
    </div>
  </div>
</div>

<!-- ADMIN PANEL -->
<div id="adminPanel" style="display:none;">
  <header>
    <div>
      <div class="logo">Admin <span>Tony</span> Tony</div>
      <div style="font-size:11px;color:#aaa;">Panel de Administración</div>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
      <button onclick="toggleDark()" id="darkBtn" style="background:none;border:none;font-size:22px;cursor:pointer;">🌙</button>
      <button onclick="lockPanel()" style="background:var(--rojo);color:white;border:none;border-radius:50px;padding:8px 14px;font-family:'Nunito',sans-serif;font-weight:800;font-size:13px;cursor:pointer;">🔒 Salir</button>
    </div>
  </header>

  <div class="tabs">
    <button class="tab-btn active" onclick="showAdminTab('productos')" id="tab-productos">📦 Productos</button>
    <button class="tab-btn" onclick="showAdminTab('pedidos')" id="tab-pedidos">📋 Pedidos</button>
    <button class="tab-btn" onclick="showAdminTab('repartidores')" id="tab-repartidores">🛵 Repartidores</button>
    <button class="tab-btn" onclick="showAdminTab('zonas')" id="tab-zonas">🗺️ Zonas</button>
    <button class="tab-btn" onclick="showAdminTab('cupones')" id="tab-cupones">🎟️ Cupones</button>
    <button class="tab-btn" onclick="showAdminTab('soporte')" id="tab-soporte">📞 Soporte</button>
    <button class="tab-btn" onclick="showAdminTab('config')" id="tab-config">⚙️ Config</button>
  </div>

  <!-- PRODUCTOS -->
  <div class="view active" id="view-productos">
    <div class="admin-section">
      <h3>➕ Agregar Producto</h3>
      <label for="newPhoto" style="cursor:pointer;display:block;">
        <div class="photo-upload-area" id="photoPreview"><span style="font-size:30px">📸</span><span>Toca para agregar foto</span></div>
        <input type="file" id="newPhoto" accept="image/*" style="display:none;" onchange="previewPhoto(this)">
      </label>
      <div class="form-row">
        <input type="text" id="newEmoji" placeholder="Emoji 🍎" maxlength="4" style="max-width:80px;text-align:center;font-size:20px;">
        <input type="text" id="newName" placeholder="Nombre del producto">
      </div>
      <div class="form-row">
        <input type="number" id="newPrice" placeholder="Precio ($)" min="0" step="0.01">
        <input type="text" id="newCategory" placeholder="Categoría">
      </div>
      <div class="form-row">
        <select id="newEtiqueta" style="flex:1;padding:10px 14px;border:2px solid var(--border);border-radius:10px;font-family:'Nunito',sans-serif;font-size:14px;outline:none;background:var(--bg);color:var(--text);">
          <option value="">Sin etiqueta</option>
          <option value="popular">⭐ Popular</option>
          <option value="recomendado">👍 Recomendado</option>
          <option value="hoy">⏰ Oferta por hoy</option>
        </select>
        <select id="newTipo" style="flex:1;padding:10px 14px;border:2px solid var(--border);border-radius:10px;font-family:'Nunito',sans-serif;font-size:14px;outline:none;background:var(--bg);color:var(--text);">
          <option value="normal">Normal</option>
          <option value="combo">📦 Combo</option>
        </select>
      </div>
      <div class="form-row">
        <label style="display:flex;align-items:center;gap:8px;flex:1;font-weight:700;font-size:14px;cursor:pointer;padding:10px;border:2px solid var(--border);border-radius:10px;">
          <input type="checkbox" id="newOferta" style="width:18px;height:18px;accent-color:var(--rojo);">🔥 Es oferta
        </label>
        <input type="number" id="newPrecioAnterior" placeholder="Precio anterior $" min="0" step="0.01" style="flex:1;">
        <label style="display:flex;align-items:center;gap:6px;flex:0.7;font-weight:700;font-size:13px;cursor:pointer;padding:10px;border:2px solid var(--border);border-radius:10px;">
          <input type="checkbox" id="newVisible" checked style="width:18px;height:18px;accent-color:var(--verde);">👁️ Visible
        </label>
      </div>
      <!-- 7. AGOTADO + STOCK -->
      <div class="form-row">
        <label style="display:flex;align-items:center;gap:8px;flex:1;font-weight:700;font-size:13px;cursor:pointer;padding:10px;border:2px solid var(--border);border-radius:10px;">
          <input type="checkbox" id="newAgotado" style="width:18px;height:18px;accent-color:#555;">❌ Agotado
        </label>
        <input type="number" id="newStock" placeholder="Stock (opcional)" min="0" step="1" style="flex:1;">
      </div>
      <div class="variants-input-area">
        <label>🎨 Variantes (sabores, tamaños) — opcional</label>
        <div class="variant-tags" id="variantTags"></div>
        <div class="variant-add-row">
          <input type="text" id="variantInput" placeholder="ej: Cola, Uva..." onkeyup="if(event.key==='Enter')addVariantTag()">
          <button onclick="addVariantTag()">+ Agregar</button>
        </div>
      </div>
      <button class="btn-primary" onclick="addProduct()" style="width:100%;">✅ Agregar Producto</button>
    </div>

    <div class="admin-section">
      <h3>📦 Mis Productos</h3>
      <div style="margin-bottom:10px;">
        <input type="text" id="adminSearch" placeholder="🔍 Buscar producto..." oninput="renderProductList()" style="width:100%;padding:10px 14px;border:2px solid var(--border);border-radius:10px;font-family:'Nunito',sans-serif;font-size:14px;outline:none;background:var(--bg);color:var(--text);">
      </div>
      <div class="product-list-admin" id="adminProductList"></div>
    </div>

    <div style="text-align:center;padding-bottom:20px;">
      <button onclick="cargarInventario()" style="background:none;border:2px solid var(--border);border-radius:12px;padding:10px 20px;font-family:'Nunito',sans-serif;font-size:13px;cursor:pointer;color:var(--subtext);">📦 Cargar inventario inicial</button>
    </div>
  </div>

  <!-- PEDIDOS -->
  <div class="view" id="view-pedidos">
    <!-- STATS RÁPIDAS EN PEDIDOS -->
    <div id="pedidosStatsBar" style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:14px;"></div>
    <div class="admin-section">
      <h3>📋 Pedidos</h3>
      <div style="display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap;">
        <button onclick="filterPedidos('todos')" id="fp-todos" class="btn-primary" style="font-size:12px;padding:6px 12px;border-radius:50px;">Todos</button>
        <button onclick="filterPedidos('pendiente')" id="fp-pendiente" style="background:var(--gris);border:none;border-radius:50px;padding:6px 12px;font-family:'Nunito',sans-serif;font-weight:700;font-size:12px;cursor:pointer;color:var(--text);">⏳ Pendientes</button>
        <button onclick="filterPedidos('confirmado')" id="fp-confirmado" style="background:var(--gris);border:none;border-radius:50px;padding:6px 12px;font-family:'Nunito',sans-serif;font-weight:700;font-size:12px;cursor:pointer;color:var(--text);">✅ Confirmados</button>
        <button onclick="filterPedidos('preparacion')" id="fp-preparacion" style="background:var(--gris);border:none;border-radius:50px;padding:6px 12px;font-family:'Nunito',sans-serif;font-weight:700;font-size:12px;cursor:pointer;color:var(--text);">🍳 Preparando</button>
        <button onclick="filterPedidos('camino')" id="fp-camino" style="background:var(--gris);border:none;border-radius:50px;padding:6px 12px;font-family:'Nunito',sans-serif;font-weight:700;font-size:12px;cursor:pointer;color:var(--text);">🛵 En camino</button>
        <button onclick="filterPedidos('entregado')" id="fp-entregado" style="background:var(--gris);border:none;border-radius:50px;padding:6px 12px;font-family:'Nunito',sans-serif;font-weight:700;font-size:12px;cursor:pointer;color:var(--text);">📦 Entregados</button>
        <button onclick="filterPedidos('cancelado')" id="fp-cancelado" style="background:var(--gris);border:none;border-radius:50px;padding:6px 12px;font-family:'Nunito',sans-serif;font-weight:700;font-size:12px;cursor:pointer;color:var(--text);">❌ Cancelados</button>
      </div>
      <div id="pedidosList"><p style="color:var(--subtext);">Cargando pedidos...</p></div>
    </div>
  </div>

  <!-- REPARTIDORES -->
  <div class="view" id="view-repartidores">
    <div class="admin-section">
      <h3>➕ Agregar Repartidor</h3>
      <div class="form-row">
        <input type="text" id="repNombre" placeholder="Nombre completo">
        <input type="tel" id="repTelefono" placeholder="Teléfono">
      </div>
      <div class="form-row">
        <input type="text" id="repPlaca" placeholder="Placa del vehículo">
        <input type="text" id="repVehiculo" placeholder="Tipo (moto, carro...)">
      </div>
      <button class="btn-primary" onclick="addRepartidor()" style="width:100%;">✅ Agregar Repartidor</button>
    </div>
    <div class="admin-section">
      <h3>🛵 Repartidores</h3>
      <div id="repartidoresList"></div>
    </div>
  </div>

  <!-- ZONAS -->
  <div class="view" id="view-zonas">
    <div class="admin-section">
      <h3>➕ Agregar Zona</h3>
      <div class="form-row">
        <input type="text" id="zonaNombre" placeholder="Nombre de la zona">
        <input type="number" id="zonaCosto" placeholder="Costo ($)" min="0" step="0.5">
      </div>
      <button class="btn-primary" onclick="addZona()" style="width:100%;">✅ Agregar Zona</button>
    </div>
    <div class="admin-section">
      <h3>🗺️ Zonas de entrega</h3>
      <div id="zonasList"></div>
    </div>
  </div>

  <!-- CUPONES -->
  <div class="view" id="view-cupones">
    <div class="admin-section">
      <h3>➕ Crear Cupón</h3>
      <div class="form-row">
        <input type="text" id="cuponCodigo" placeholder="Código (ej: TONY10)" style="text-transform:uppercase;">
        <select id="cuponTipo" style="flex:1;padding:10px 14px;border:2px solid var(--border);border-radius:10px;font-family:'Nunito',sans-serif;font-size:14px;outline:none;background:var(--bg);color:var(--text);">
          <option value="porcentaje">% Porcentaje</option>
          <option value="fijo">$ Monto fijo</option>
        </select>
      </div>
      <div class="form-row">
        <input type="number" id="cuponDescuento" placeholder="Valor (ej: 10 = 10%)" min="1">
        <input type="date" id="cuponExpira" placeholder="Fecha expiración (opcional)">
      </div>
      <button class="btn-primary" onclick="crearCupon()" style="width:100%;">✅ Crear Cupón</button>
    </div>
    <div class="admin-section">
      <h3>🎟️ Cupones activos</h3>
      <div id="cuponesList"><p style="color:var(--subtext);">Cargando...</p></div>
    </div>
  </div>

  <!-- 14. SOPORTE -->
